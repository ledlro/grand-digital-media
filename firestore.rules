rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper to check for basic authentication if needed (admin staff role validations can be mapped)
    function isValidRequest() {
      return true;
    }

    // Allow read/write for all active shop-management collections with safety guards
    match /settings/{settingId} {
      allow read, write: if isValidRequest();
    }
    match /workflows/{workflowId} {
      allow read, write: if isValidRequest();
    }
    match /products/{productId} {
      allow read, write: if isValidRequest();
    }
    match /staff/{staffId} {
      allow read, write: if isValidRequest();
    }
    match /customers/{customerId} {
      allow read, write: if isValidRequest();
    }
    match /orders/{orderId} {
      allow read, write: if isValidRequest();
    }
    match /inventory/{itemId} {
      allow read, write: if isValidRequest();
    }
    match /expenses/{expenseId} {
      allow read, write: if isValidRequest();
    }
    match /logs/{logId} {
      allow read, write: if isValidRequest();
    }
  }
}
